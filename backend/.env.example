# Application
APP_NAME=Blog Index Analyzer
APP_ENV=development
DEBUG=true
API_VERSION=v1

# Server
HOST=0.0.0.0
PORT=8000

# Database - PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=blog_analyzer
POSTGRES_USER=admin
POSTGRES_PASSWORD=your_secure_password
DATABASE_URL=postgresql://admin:your_secure_password@localhost:5432/blog_analyzer

# Database - MongoDB
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DB=blog_analyzer_logs
MONGO_USER=admin
MONGO_PASSWORD=your_secure_password
MONGO_URL=mongodb://admin:your_secure_password@localhost:27017/blog_analyzer_logs

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# JWT Authentication
# IMPORTANT: Generate a secure random SECRET_KEY for production
# You can generate one using: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Or: openssl rand -hex 32
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Naver API
NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret

# Naver Ad API (for keyword search volume and related keywords)
NAVER_AD_API_KEY=your_naver_ad_api_key
NAVER_AD_SECRET_KEY=your_naver_ad_secret_key
NAVER_AD_CUSTOMER_ID=your_naver_ad_customer_id

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# Crawler Settings
CRAWLER_USER_AGENTS=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36
CRAWLER_TIMEOUT_MS=30000
CRAWLER_MAX_RETRIES=3
CRAWLER_DELAY_SECONDS=1.0

# Proxy (Optional)
USE_PROXY=false
PROXY_LIST=

# Monitoring
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# Email (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@bloganalyzer.com

# AWS (Optional - for deployment)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-northeast-2
S3_BUCKET=

# Subscription Plans
FREE_DAILY_LIMIT=3
BASIC_DAILY_LIMIT=20
PRO_DAILY_LIMIT=100
