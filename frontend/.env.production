# Production Environment Variables for Vercel
# Fly.io 백엔드 사용 (blog-index-analyzer.fly.dev)

# Backend API URL
NEXT_PUBLIC_API_URL=https://blog-index-analyzer.fly.dev
NEXT_PUBLIC_API_BASE_URL=https://blog-index-analyzer.fly.dev
API_BASE_URL=https://blog-index-analyzer.fly.dev

# App Configuration
NEXT_PUBLIC_APP_NAME=블랭크
NEXT_PUBLIC_APP_ENV=production

# Feature Flags
NEXT_PUBLIC_ENABLE_DARK_MODE=true

# 토스페이먼츠 (실제 사용 시 토스페이먼츠에서 발급받은 키로 교체)
NEXT_PUBLIC_TOSS_CLIENT_KEY=
